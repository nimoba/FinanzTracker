{
  "framework": "vite",
  "buildCommand": "cd client && npm install && ./node_modules/.bin/tsc -b && npx vite build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/" }
  ]
}